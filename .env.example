# 前端环境变量（Vite）
# 本地开发时可将 VITE_AGENT_API_BASE_URL 置空，使用 /api/chat 代理到本地后端
VITE_AGENT_API_BASE_URL=
VITE_AGENT_CHAT_PATH=/api/chat
VITE_AGENT_API_KEY=
VITE_AGENT_API_KEY_HEADER=Authorization
VITE_AGENT_TIMEOUT_MS=0
VITE_AGENT_ENABLE_FALLBACK_MOCK=false
VITE_AGENT_MODEL=6514ae87b0d343059a30840269606735
VITE_AGENT_STREAM=false
VITE_AGENT_MAX_TOKENS=50000
VITE_AGENT_TEMPERATURE=1.5

# 后端环境变量（仅在使用后端网关或生产 Node 时需要）
# 本项目默认后端端口为 5174，可通过 PORT 覆盖
PORT=5174
SITE_DOMAIN=
ALLOWED_ORIGIN=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_API_KEY=
DASHSCOPE_AGENT_APP_ID=6514ae87b0d343059a30840269606735
AGENT_TIMEOUT_MS=0
